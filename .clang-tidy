# LLVM-derived check set, tuned to cut noise for a numeric/HFT codebase.
# NOTE: `#` comments are NOT allowed inside the `Checks:` scalar (it is a single
# comma-separated string), so the rationale for the disables lives here:
#   - braces-around-statements        : LLVM single-statement style (matches the code)
#   - reinterpret-cast / array-decay / avoid-c-arrays / constant-array-index
#                                       : the binary records are fixed C layouts mmapped
#                                         and read in place
#   - const-or-ref-data-members        : components hold injected references (DI)
#   - special-member-functions / prefer-member-initializer / type-member-init
#                                       : move-only RAII types; records value-init'd at use
#   - pro-type-vararg / use-std-print  : printf is intentional in the CLI apps
#   - use-designated-initializers / use-auto / use-ranges / easily-swappable-parameters
#                                       : pedantic for tiny internal aggregates/algos
#   - exception-escape                 : escapes are theoretical (bad_alloc / valueless variant)
---
Checks: >
  -*,
  bugprone-*,
  performance-*,
  modernize-*,
  readability-*,
  cppcoreguidelines-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -readability-identifier-length,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-avoid-do-while,
  -readability-braces-around-statements,
  -bugprone-easily-swappable-parameters,
  -modernize-use-ranges,
  -cppcoreguidelines-special-member-functions,
  -cppcoreguidelines-avoid-const-or-ref-data-members,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-avoid-c-arrays,
  -modernize-avoid-c-arrays,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-type-member-init,
  -cppcoreguidelines-prefer-member-initializer,
  -readability-convert-member-functions-to-static,
  -modernize-use-std-print,
  -modernize-use-designated-initializers,
  -modernize-use-auto,
  -bugprone-exception-escape
WarningsAsErrors: ''
HeaderFilterRegex: 'include/bt/'
FormatStyle: file
